int romanToInt(char* s) {
	//변수 설정  #이전수, 나중수를 확인하는 plus1,2 
    int plus1=0;
    int plus2=99999; //아래 반복문 i=0 일때 if(plus1>plus2)문에 걸리지 않도록 사전 큰수 설정
    int sum=0;
    
    for(int i=0;i<15;i++){ //로마숫자에 맞는 조건문 설정
        if(s[i]=='I'){
            plus1=1;
        }
        else if(s[i]=='V'){
            plus1=5;
        }
        else if(s[i]=='X'){
            plus1=10;
        }
        else if(s[i]=='L'){
            plus1=50;
        }
        else if(s[i]=='C'){
            plus1=100;
        }
        else if(s[i]=='D'){
            plus1=500;
        }
        else if(s[i]=='M'){
            plus1=1000;
        }
        else{
            break;
        }
        if(plus1>plus2){  // 만약 먼저 입력된 로마숫자 보다 나중 로마숫자가 더 크다면
            sum=sum+(plus1-plus2); //선 후 입력의 plus의 차를 sum에 더함
            sum-=plus2; // 그후 전에 sum 에 반영된 로마숫자를 빼줌
    	}
        else{
            sum+=plus1; //위 조건이 아니라면  그냥 더함
        }
        plus2=plus1; //후입력 로마와의 연산을 위해 plus2에 plus1 저장
    }
    return sum; 
}
