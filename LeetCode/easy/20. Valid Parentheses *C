//연속된 자료값을 하나씩 확인 하기 위해 스택 개념을 사용 

#include<string.h>

bool isValid(char* s) {
    int len = strlen(s);  
    if (len % 2 != 0) return false;

    char stack[len]; //길이에 맞는 스택배열 생성 
    int top = -1; //스택 값을 읽는 인덱스를 top을 -1로 생성  

    for (int i = 0; i < len; i++) {
    	
		char ch = s[i]; //s의 값을 ch에 입력 
		
        if (ch == '(' || ch == '{' || ch == '[') {
            stack[++top] = ch; //위 조건에 만족하면 ch값을 스택에 추가 
        } 
        else {
            if (top == -1) return false; //첫 문자가 )}]중 하나면 거짓임 
            char open = stack[top--]; //스택 값을 차례로 뺴면서 닫친 괄호를 비교 
            if ((open == '(' && ch != ')') ||
                (open == '{' && ch != '}') ||
                (open == '[' && ch != ']')) {
                return false;
            }
        }
    }
	
    return top == -1; //만약 스택의 값이 모두 빠져나온다면 true 
}
