struct ListNode* mergeTwoLists(struct ListNode* list1, struct ListNode* list2) {
    //list1, list2를 오름차순으로 정렬해줄 리스트 생성
    struct ListNode list; //메모리 공간 생성
    struct ListNode* plist=&list; //메모리 공간의 포인터 노드구조체 생성
    list.next=NULL; //혹시 list.next 부터 정렬된 값이 입력되므로 초기화 (안정성)

    while(list1!=NULL && list2!=NULL){ //리스트의 끝까지 반복
        if(list1->val <= list2->val){ //리스트의 값을 비교
            plist->next=list1; //더 작은 값을 포인터 list.next에 입력
            list1=list1->next; // 그 후 list1의 다음값을 list1에 불러옴
        }
        else{
            plist->next=list2; //위 절차와 동일
            list2=list2->next;
        }
        plist=plist->next; //비교가 끝나고 plist 다음 노드로 이동
    }

    if(list1!=NULL){  //마지막남은 list1,2의 값을 찾는 조건문
        plist->next=list1; //조건문에 따라 merged list에 마지막 값을 입력
    }
    else {
        plist->next=list2;
    }

    return list.next; //list.next부터 오름차순 정렬되어있으므로 값을 반환
}
