bool isPalindrome(int x) {
    if(x<0){
    	//입력받은 x가 음수면 false
        return false;
    }
    
    long long int reversed=0; // 밑에 연산 과정에서 10을 곱하는데 submit 과정에서 overflow발생해서 longlongint 사용
    int ox=x; // 밑 연산 과정에서 x값을 변경하므로 reversed 값과 비교할 x의 원본 변수 생성
    
    while (x > 0) {
        reversed = (reversed * 10) + (x % 10);
        x = x / 10;
    }
    
    if(ox==reversed){
        return true;
    }
    
    return false;
}
